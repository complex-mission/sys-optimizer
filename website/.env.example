# ===== 服务 =====
# 监听端口(由 scripts/start.js 读取;shell 环境变量 PORT 优先;默认 3000)
PORT=11114

# ===== 阿里云访问凭证(RAM 用户,需具备 sts:AssumeRole 权限)=====
ALIYUN_ACCESS_KEY_ID=LTAI5txxxxxxxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== STS 角色(该角色的授权策略需覆盖下方 bucket 的读写)=====
ALIYUN_ROLE_ARN=acs:ram::1234567890123456:role/sysoptimizer-site
ALIYUN_ROLE_SESSION_NAME=sysoptimizer-site
# STS 临时凭证有效期,秒(900 ~ 角色 MaxSessionDuration)
STS_DURATION_SECONDS=3600

# ===== OSS(私有桶)=====
OSS_REGION=oss-cn-beijing
OSS_BUCKET=sysoptimizer-releases
# 文件统一放在该前缀下(可为空;以 / 结尾)
OSS_PREFIX=releases/

# ===== 管理后台 =====
# 单密码,明文保存于此
ADMIN_PASSWORD=change-me
# 后台隐藏入口路径段:后台地址为 /zh/<ADMIN_PATH> 或 /en/<ADMIN_PATH>
# 请换成随机字符串;猜错路径一律返回 404;留空 = 禁用后台页面
ADMIN_PATH=2lwdkehdf66
# 登录态有效期,秒(默认 7 天)
ADMIN_SESSION_TTL_SECONDS=604800

# ===== 下载 =====
# 签名下载链接有效期,秒
DOWNLOAD_URL_TTL_SECONDS=300
# 每个 IP 每小时最多允许的下载次数(请求级限流)
DOWNLOAD_RATE_LIMIT_PER_HOUR=20
# 单连接限速,KB/s(OSS x-oss-traffic-limit;留空 = 不限速;最小 30)
DOWNLOAD_SPEED_LIMIT_KBPS=2048

# ===== 日志 =====
# 下载日志目录(JSONL 追加写入)
LOG_DIR=./data
