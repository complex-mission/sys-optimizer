{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SysOptimizer",
  "version": "1.0.0",
  "identifier": "com.shenyangxinshang.cacheinsight",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "系统优化助手 SysOptimizer",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "信商科技",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "sidebarImage": "./windows/installer-sidebar.bmp",
        "headerImage": "./windows/installer-header.bmp",
        "installerHooks": "./windows/hooks.nsh",
        "template": "./windows/installer.nsi",
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "copyright": "© 2026 沈阳信商科技 版权所有 · 技术支持 解构者",
    "shortDescription": "垃圾清理与系统洞察工具",
    "longDescription": "系统优化助手(SysOptimizer)— 看清磁盘去了哪,清得放心。"
  }
}
