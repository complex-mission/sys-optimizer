{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "系统优化助手主窗口默认能力:允许前端使用核心事件监听(扫描/分析进度)、窗口控制与对话框插件。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-set-theme",
    "core:webview:default",
    "dialog:default"
  ]
}
